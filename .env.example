# tl;dr — Configuração de Ambiente
#
# Copie este arquivo para .env e preencha com suas credenciais:
#   cp .env.example .env
#
# ATENÇÃO: Nunca commite o .env com credenciais reais!

# Obrigatória: chave de API do provedor (Apiário ou compatível OpenAI)
# TLDR_API_KEY=sk-sua-chave-aqui

# Opcional: URL base da API (default: https://api.apiario.dev/v1)
# TLDR_BASE_URL=https://api.apiario.dev/v1

# Opcional: modelo padrão (default: deepseek/deepseek-v4-flash)
# TLDR_DEFAULT_MODEL=deepseek/deepseek-v4-flash

# Opcional: idioma padrão
# TLDR_DEFAULT_LANG=pt-br

# Opcional: timeout da requisição em segundos (default: 30)
# TLDR_TIMEOUT=30
